# Perplexity Sonar API (トピック生成用 — 必須)
# https://www.perplexity.ai/api-platform でAPIキーを取得
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# OpenAI API (台本生成用 — 必須)
# https://platform.openai.com/api-keys でAPIキーを取得
OPENAI_API_KEY=your_openai_api_key_here

# GNews API (トレンドデータ補完 — 任意)
# https://gnews.io/ でAPIキーを取得（無料100リクエスト/日）
GNEWS_API_KEY=your_gnews_api_key_here

# X (Twitter) API (SNSトレンド — 任意)
# https://developer.x.com/ でBearer Tokenを取得
X_API_BEARER_TOKEN=your_x_bearer_token_here

# YouTube Data API (トレンド — 任意)
YOUTUBE_API_KEY=your_youtube_api_key_here

# NewsAPI (ニュース補完 — 任意)
NEWS_API_KEY=your_newsapi_key_here

# Supabase Configuration (optional - falls back to LocalStorage/in-memory if not set)
# https://supabase.com/dashboard でプロジェクトを作成してください
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (server-side only, optional)
# RLS をバイパスしてサーバーサイドから直接 DB アクセスする場合に使用
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cache TTL Configuration (optional, milliseconds)
# CACHE_TTL_TOPIC_MS=1800000
# CACHE_TTL_SCRIPT_MS=10800000
# CACHE_TTL_BATCH_MS=2700000

# Vercel Cron認証シークレット
CRON_SECRET=your_cron_secret_here